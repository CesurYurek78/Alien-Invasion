import pygame
import random
import sys
import math

# Initialisierung von Pygame
pygame.init()

# Fenstergröße
WIDTH, HEIGHT = 800, 600
screen = pygame.display.set_mode((WIDTH, HEIGHT))
pygame.display.set_caption("Space Invaders")

# Farben
BLACK = (0, 0, 0)
WHITE = (255, 255, 255)
GREEN = (0, 255, 0)
RED = (255, 0, 0)
BLUE = (0, 120, 255)
YELLOW = (255, 255, 0)
PURPLE = (180, 0, 255)

# Spielerklasse
class Player:
    def __init__(self):
        self.width = 50
        self.height = 30
        self.x = WIDTH // 2 - self.width // 2
        self.y = HEIGHT - 50
        self.speed = 6
        self.color = GREEN
        self.lives = 3
        self.score = 0
        self.shoot_cooldown = 0

    def draw(self):
        # Raumschiff zeichnen
        pygame.draw.polygon(screen, self.color, [
            (self.x + self.width // 2, self.y),  # Spitze
            (self.x, self.y + self.height),      # Links unten
            (self.x + self.width, self.y + self.height)  # Rechts unten
        ])
        
        # Leben anzeigen
        for i in range(self.lives):
            pygame.draw.polygon(screen, GREEN, [
                (20 + i * 30, 20),
                (10 + i * 30, 40),
                (30 + i * 30, 40)
            ])

    def move(self, direction):
        if direction == "left" and self.x > 0:
            self.x -= self.speed
        if direction == "right" and self.x < WIDTH - self.width:
            self.x += self.speed
    
    def shoot(self):
        if self.shoot_cooldown <= 0:
            self.shoot_cooldown = 15
            return Bullet(self.x + self.width // 2 - 2, self.y, -10, GREEN)
        return None
    
    def update(self):
        if self.shoot_cooldown > 0:
            self.shoot_cooldown -= 1

# Alienklasse
class Alien:
    def __init__(self, x, y, alien_type):
        self.width = 40
        self.height = 40
        self.x = x
        self.y = y
        self.speed = 1
        self.direction = 1
        self.alien_type = alien_type  # 0, 1 oder 2 für verschiedene Alien-Typen
        self.color = [RED, YELLOW, PURPLE][alien_type]
        self.points = [100, 50, 150][alien_type]
        self.shoot_chance = 0.002 if alien_type == 0 else 0.001  # Rote Aliens schießen öfter

    def draw(self):
        # Alienkörper zeichnen
        pygame.draw.rect(screen, self.color, (self.x, self.y, self.width, self.height), border_radius=8)
        
        # Alien-Augen zeichnen
        eye_size = 6
        pygame.draw.circle(screen, WHITE, (self.x + self.width // 3, self.y + self.height // 3), eye_size)
        pygame.draw.circle(screen, WHITE, (self.x + 2 * self.width // 3, self.y + self.height // 3), eye_size)
        pygame.draw.circle(screen, BLACK, (self.x + self.width // 3, self.y + self.height // 3), eye_size // 2)
        pygame.draw.circle(screen, BLACK, (self.x + 2 * self.width // 3, self.y + self.height // 3), eye_size // 2)

    def move(self):
        self.x += self.speed * self.direction
        
    def drop_down(self):
        self.y += 20
        self.direction *= -1  # Richtung umkehren
        
    def shoot(self):
        if random.random() < self.shoot_chance:
            return Bullet(self.x + self.width // 2 - 2, self.y + self.height, 4, RED)
        return None

# Geschossklasse
class Bullet:
    def __init__(self, x, y, speed, color):
        self.width = 4
        self.height = 15
        self.x = x
        self.y = y
        self.speed = speed
        self.color = color

    def draw(self):
        pygame.draw.rect(screen, self.color, (self.x, self.y, self.width, self.height))

    def move(self):
        self.y += self.speed
        
    def off_screen(self):
        return self.y < 0 or self.y > HEIGHT

# Hindernisklasse
class Barrier:
    def __init__(self, x, y):
        self.x = x
        self.y = y
        self.width = 80
        self.height = 40
        self.blocks = []
        self.create_blocks()
        
    def create_blocks(self):
        block_size = 8
        for row in range(5):
            for col in range(10):
                # Erzeuge eine Lücke in der Mitte
                if not (row >= 2 and 4 <= col <= 5):
                    self.blocks.append([self.x + col * block_size, self.y + row * block_size])
    
    def draw(self):
        for block in self.blocks:
            pygame.draw.rect(screen, BLUE, (block[0], block[1], 8, 8))
    
    def check_collision(self, bullet):
        for block in self.blocks[:]:
            if (bullet.x < block[0] + 8 and bullet.x + bullet.width > block[0] and
                bullet.y < block[1] + 8 and bullet.y + bullet.height > block[1]):
                self.blocks.remove(block)
                return True
        return False

# Spielinitialisierung
player = Player()
aliens = []
alien_bullets = []
player_bullets = []
barriers = []

# Aliens erstellen
for row in range(5):
    for col in range(10):
        alien_type = 0 if row == 0 else (1 if row < 3 else 2)
        aliens.append(Alien(col * 60 + 50, row * 50 + 50, alien_type))

# Hindernisse erstellen
for i in range(4):
    barriers.append(Barrier(i * 180 + 100, HEIGHT - 150))

# Spielvariablen
alien_move_counter = 0
alien_move_delay = 30  # Je niedriger, desto schneller bewegen sich die Aliens
game_over = False
game_won = False
level = 1
clock = pygame.time.Clock()
font = pygame.font.SysFont(None, 36)

# Explosions-Effekt-Klasse
class Explosion:
    def __init__(self, x, y):
        self.x = x
        self.y = y
        self.radius = 5
        self.max_radius = 20
        self.growth_rate = 1.5
        self.active = True
        
    def update(self):
        self.radius += self.growth_rate
        if self.radius >= self.max_radius:
            self.active = False
            
    def draw(self):
        pygame.draw.circle(screen, YELLOW, (int(self.x), int(self.y)), int(self.radius), 2)
        pygame.draw.circle(screen, RED, (int(self.x), int(self.y)), int(self.radius) - 4, 2)

explosions = []

# Hauptspiel-Schleife
while True:
    # Event-Verarbeitung
    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            pygame.quit()
            sys.exit()
        
        if event.type == pygame.KEYDOWN:
            if event.key == pygame.K_SPACE and not game_over and not game_won:
                bullet = player.shoot()
                if bullet:
                    player_bullets.append(bullet)
            if event.key == pygame.K_r and (game_over or game_won):
                # Spiel zurücksetzen
                player = Player()
                aliens = []
                alien_bullets = []
                player_bullets = []
                barriers = []
                explosions = []
                
                # Aliens neu erstellen
                for row in range(5):
                    for col in range(10):
                        alien_type = 0 if row == 0 else (1 if row < 3 else 2)
                        aliens.append(Alien(col * 60 + 50, row * 50 + 50, alien_type))
                
                # Hindernisse neu erstellen
                for i in range(4):
                    barriers.append(Barrier(i * 180 + 100, HEIGHT - 150))
                
                game_over = False
                game_won = False
                alien_move_counter = 0
                level = 1
    
    if not game_over and not game_won:
        # Spielerbewegung
        keys = pygame.key.get_pressed()
        if keys[pygame.K_LEFT]:
            player.move("left")
        if keys[pygame.K_RIGHT]:
            player.move("right")
        
        # Spielerupdate
        player.update()
        
        # Aliens bewegen
        alien_move_counter += 1
        move_down = False
        
        # Prüfen, ob Aliens den Rand erreichen
        for alien in aliens:
            if alien.x <= 0 or alien.x >= WIDTH - alien.width:
                move_down = True
                break
        
        # Aliens bewegen oder nach unten bewegen
        if alien_move_counter >= alien_move_delay:
            alien_move_counter = 0
            for alien in aliens:
                if move_down:
                    alien.drop_down()
                    # Erhöhe Geschwindigkeit mit jedem Abstieg
                    if alien.speed < 3:
                        alien.speed += 0.05
                else:
                    alien.move()
        
        # Aliens schießen lassen
        for alien in aliens:
            bullet = alien.shoot()
            if bullet:
                alien_bullets.append(bullet)
        
        # Spieler-Geschosse bewegen
        for bullet in player_bullets[:]:
            bullet.move()
            if bullet.off_screen():
                player_bullets.remove(bullet)
        
        # Alien-Geschosse bewegen
        for bullet in alien_bullets[:]:
            bullet.move()
            if bullet.off_screen():
                alien_bullets.remove(bullet)
        
        # Kollisionserkennung: Spieler-Geschosse mit Aliens
        for bullet in player_bullets[:]:
            for alien in aliens[:]:
                if (bullet.x < alien.x + alien.width and bullet.x + bullet.width > alien.x and
                    bullet.y < alien.y + alien.height and bullet.y + bullet.height > alien.y):
                    
                    # Explosionseffekt hinzufügen
                    explosions.append(Explosion(alien.x + alien.width // 2, alien.y + alien.height // 2))
                    
                    player.score += alien.points
                    player_bullets.remove(bullet)
                    aliens.remove(alien)
                    break
        
        # Kollisionserkennung: Alien-Geschosse mit Spieler
        for bullet in alien_bullets[:]:
            if (bullet.x < player.x + player.width and bullet.x + bullet.width > player.x and
                bullet.y < player.y + player.height and bullet.y + bullet.height > player.y):
                
                # Explosionseffekt hinzufügen
                explosions.append(Explosion(player.x + player.width // 2, player.y + player.height // 2))
                
                alien_bullets.remove(bullet)
                player.lives -= 1
                if player.lives <= 0:
                    game_over = True
        
        # Kollisionserkennung: Geschosse mit Hindernissen
        for barrier in barriers:
            for bullet in player_bullets[:]:
                if barrier.check_collision(bullet):
                    if bullet in player_bullets:
                        player_bullets.remove(bullet)
            
            for bullet in alien_bullets[:]:
                if barrier.check_collision(bullet):
                    if bullet in alien_bullets:
                        alien_bullets.remove(bullet)
        
        # Prüfen, ob Aliens den Spieler erreichen
        for alien in aliens:
            if alien.y + alien.height >= player.y:
                game_over = True
        
        # Prüfen, ob alle Aliens besiegt sind
        if len(aliens) == 0:
            game_won = True
        
        # Explosionen aktualisieren
        for explosion in explosions[:]:
            explosion.update()
            if not explosion.active:
                explosions.remove(explosion)
    
    # Hintergrund zeichnen
    screen.fill(BLACK)
    
    # Sterne im Hintergrund zeichnen
    for i in range(100):
        x = random.randint(0, WIDTH)
        y = random.randint(0, HEIGHT)
        size = random.randint(1, 3)
        brightness = random.randint(150, 255)
        pygame.draw.circle(screen, (brightness, brightness, brightness), (x, y), size)
    
    # Hindernisse zeichnen
    for barrier in barriers:
        barrier.draw()
    
    # Aliens zeichnen
    for alien in aliens:
        alien.draw()
    
    # Geschosse zeichnen
    for bullet in player_bullets:
        bullet.draw()
    
    for bullet in alien_bullets:
        bullet.draw()
    
    # Spieler zeichnen
    player.draw()
    
    # Explosionen zeichnen
    for explosion in explosions:
        explosion.draw()
    
    # Punktestand anzeigen
    score_text = font.render(f"Punkte: {player.score}", True, WHITE)
    screen.blit(score_text, (WIDTH - 150, 20))
    
    # Level anzeigen
    level_text = font.render(f"Level: {level}", True, WHITE)
    screen.blit(level_text, (WIDTH - 150, 60))
    
    # Spielende-Anzeige
    if game_over:
        game_over_text = font.render("GAME OVER", True, RED)
        restart_text = font.render("Drücke R zum Neustart", True, WHITE)
        screen.blit(game_over_text, (WIDTH // 2 - 80, HEIGHT // 2 - 50))
        screen.blit(restart_text, (WIDTH // 2 - 120, HEIGHT // 2))
    
    if game_won:
        win_text = font.render("LEVEL GESCHAFFT!", True, GREEN)
        restart_text = font.render("Drücke R für das nächste Level", True, WHITE)
        screen.blit(win_text, (WIDTH // 2 - 100, HEIGHT // 2 - 50))
        screen.blit(restart_text, (WIDTH // 2 - 150, HEIGHT // 2))
    
    # Steuerungshinweise
    controls_text = font.render("Steuerung: Pfeiltasten = Bewegung, Leertaste = Schießen", True, WHITE)
    screen.blit(controls_text, (WIDTH // 2 - 300, HEIGHT - 30))
    
    # Aktualisierung des Bildschirms
    pygame.display.flip()
    
    # Framerate begrenzen
    clock.tick(60)